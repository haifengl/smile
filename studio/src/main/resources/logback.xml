<configuration>
    <!-- 1. Define a timestamp to create a unique file name for each session -->
    <timestamp key="bySession" datePattern="yyyyMMdd'T'HHmmss"/>

    <!-- 2. Console Appender for real-time viewing -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 3. File Appender that starts a new file per session -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <!-- The file name will include the startup timestamp -->
        <file>log/smile-${bySession}.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{35} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 4. Set the Root Logger level and attach both appenders -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
