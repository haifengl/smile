{
  "servers": {
    "markitdown": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "markitdown-mcp-npx"],
      "windows": {
        "command": "cmd.exe",
        "args": ["/c", "npx", "-y", "markitdown-mcp-npx"]
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "windows": {
        "command": "cmd.exe",
        "args": ["/c", "npx", "-y", "@playwright/mcp@latest"]
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "windows": {
        "command": "cmd.exe",
        "args": ["/c", "npx", "-y", "@upstash/context7-mcp"]
      }
    },
    "firecrawl": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "windows": {
        "command": "cmd.exe",
        "args": ["/c", "npx", "-y", "firecrawl-mcp"]
      }
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai"
    }
  }
}
