#!/usr/bin/env bash

echo "Installing native packages..."
if command -v brew > /dev/null; then
    brew install -q arpack
    brew install -q ripgrep
elif command -v apt-get > /dev/null; then
    sudo apt-get install -y libopenblas-dev libarpack2
    sudo apt-get install -y ripgrep
elif command -v yum > /dev/null; then
    sudo yum install -y epel-release
    sudo yum install -y openblas-devel arpack-devel
    sudo yum install -y ripgrep
elif command -v pacman > /dev/null; then
    sudo pacman -S --noconfirm openblas arpack
    sudo pacman -S --noconfirm ripgrep
else
    echo 'Unsupported Linux distribution. Please install ripgrep manually.'
fi

APP_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)
VENV_DIR="$APP_DIR/../venv"
# Check if venv directory exists
if [ ! -f "$VENV_DIR/bin/activate" ]; then
    echo "Creating Python virtual environment..."
    python3 -m venv "$VENV_DIR"
    if [ $? -ne 0 ]; then
        echo "Failed to create the virtual environment. Ensure Python is installed and added to PATH."
    else
        echo "Virtual environment created successfully."
        source "$VENV_DIR/bin/activate"
        python -m pip install --upgrade pip setuptools wheel
        pip install -r "$APP_DIR/../conf/requirements.txt"
        pip install uv
        uv tool install ty@latest

        pip install onnxruntime
        # Create a symlink to the latest libonnxruntime in the capi directory
        ONNX_CAPI_DIR=`find $VENV_DIR -type d -name "capi" -path "*/onnxruntime/capi" 2>/dev/null | head -n 1`
        ONNX_LIB=`ls -t ${ONNX_CAPI_DIR}/libonnxruntime.* | head -n 1`
        if [ -n "$ONNX_LIB" ]; then
          echo "Found ONNX capi at: ${ONNX_LIB}"
          if [[ "$OSTYPE" == "darwin"* ]]; then
            ln -sf `basename ${ONNX_LIB}` ${ONNX_CAPI_DIR}/libonnxruntime.dylib
          else
            ln -sf `basename ${ONNX_LIB}` ${ONNX_CAPI_DIR}/libonnxruntime.so
          fi
        fi
    fi
fi

